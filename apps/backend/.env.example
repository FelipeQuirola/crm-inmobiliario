NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/crm_db?schema=public"
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=crm_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_random_64_char_hex_string
JWT_REFRESH_SECRET=replace_with_another_random_64_char_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FACEBOOK_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_APP_SECRET=your_facebook_app_secret
GOOGLE_WEBHOOK_KEY=your_google_webhook_key
GENERIC_WEBHOOK_SECRET=your_generic_webhook_secret

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# UPLOADS_PATH=/root/crm/apps/backend/uploads
